{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    
     "rootDir": "./src",
     "outDir": "./dist",
    "module": "commonjs",
    "target": "esnext",
    
  
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "esModuleInterop": true,
    "strict": true,
    
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    
    "skipLibCheck": true,
  }
}
